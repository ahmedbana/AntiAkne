      "type": "custom-liquid",
      "name": "How It Works",
      "settings": {
        "custom_liquid": "<section id=\"how-it-works\" class=\"antiacne-how-it-works\">\n  <div class=\"antiacne-section-header\">\n    <span class=\"antiacne-label\">Simple & Effective</span>\n    <h2>How It Works</h2>\n    <p>Your 30-day journey to clear, radiant skin in just 3 simple steps.</p>\n  </div>\n  <div class=\"antiacne-steps\">\n    <div class=\"antiacne-step\">\n      <div class=\"antiacne-step-number\">01</div>\n      <div class=\"antiacne-step-icon\">💧</div>\n      <h3>Activate</h3>\n      <p>Remove the protective paper and spray 5–10 pumps of water onto the white nanofiber layer to activate the DrySerum.</p>\n    </div>\n    <div class=\"antiacne-step\">\n      <div class=\"antiacne-step-number\">02</div>\n      <div class=\"antiacne-step-icon\">✨</div>\n      <h3>Apply</h3>\n      <p>Gently wipe the activated pad across your face and décolleté. The nanofibers release active ingredients directly into your skin.</p>\n    </div>\n    <div class=\"antiacne-step\">\n      <div class=\"antiacne-step-number\">03</div>\n      <div class=\"antiacne-step-icon\">🌿</div>\n      <h3>Transform</h3>\n      <p>Use daily for 30 days. Phase I (days 1–15) fights acne. Phase II (days 16–30) restores balance and regenerates.</p>\n    </div>\n  </div>\n</section>",
        "color_scheme": "scheme-2",
        "section_width": "page-width",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
    "technology_section": {
      "type": "custom-liquid",
      "name": "Technology",
      "settings": {
        "custom_liquid": "<section class=\"antiacne-technology\">\n  <div class=\"antiacne-tech-grid\">\n    <div class=\"antiacne-tech-content\">\n      <span class=\"antiacne-label\">Patented Innovation</span>\n      <h2>DrySerum™ Technology</h2>\n      <p>AntiAcne is powered by <strong>NUENEX®</strong>, a patented nanofiber technology developed by RESPILON. Active ingredients are encapsulated in nanofibers and released gradually and precisely into your skin.</p>\n      <ul class=\"antiacne-tech-features\">\n        <li><span class=\"antiacne-check\">✓</span> Up to 100% natural active ingredients</li>\n        <li><span class=\"antiacne-check\">✓</span> No preservatives or synthetic fragrances</li>\n        <li><span class=\"antiacne-check\">✓</span> Clinically proven to reduce acne</li>\n        <li><span class=\"antiacne-check\">✓</span> Waterless manufacturing process</li>\n        <li><span class=\"antiacne-check\">✓</span> Eco-friendly minimal energy production</li>\n      </ul>\n    </div>\n    <div class=\"antiacne-tech-visual\">\n      <div class=\"antiacne-tech-card\">\n        <div class=\"antiacne-tech-stat\">100%</div>\n        <p>Natural Active Ingredients</p>\n      </div>\n      <div class=\"antiacne-tech-card\">\n        <div class=\"antiacne-tech-stat\">30</div>\n        <p>Day Complete Treatment</p>\n      </div>\n      <div class=\"antiacne-tech-card\">\n        <div class=\"antiacne-tech-stat\">2</div>\n        <p>Targeted Treatment Phases</p>\n      </div>\n      <div class=\"antiacne-tech-card\">\n        <div class=\"antiacne-tech-stat\">0</div>\n        <p>Preservatives & Chemicals</p>\n      </div>\n    </div>\n  </div>\n</section>",
        "color_scheme": "scheme-1",
